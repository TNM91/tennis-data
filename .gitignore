/backups/
/screenshots-*.png
/tmp-screenshots/
/app.zip
/lint-errors.txt
/type-errors.txt
/tennis-data/
/Step

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel/
test-results/

# local agent/tooling skills
.agents/
.claude/skills/
skills-lock.json

# typescript
*.tsbuildinfo
next-env.d.ts
