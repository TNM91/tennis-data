{
  "name": "tennis-data",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest --pool=threads --no-file-parallelism",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:extension": "node --check tenaceiq-capture-extension/content_script.js",
    "verify:closeout:inventory": "node scripts/verify-platform-closeout-inventory.mjs",
    "verify:closeout": "node scripts/verify-platform-closeout.mjs",
    "verify:closeout:live": "node scripts/verify-platform-closeout.mjs --live",
    "qa:prep": "node scripts/customer-journey-qa-prep.mjs",
    "qa:status": "node scripts/customer-journey-qa-status.mjs",
    "qa:next": "node scripts/customer-journey-next.mjs",
    "qa:session": "node scripts/customer-journey-session-brief.mjs",
    "qa:journey": "node scripts/customer-journey-card.mjs",
    "qa:tier": "node scripts/customer-journey-tier-card.mjs",
    "qa:day1": "node scripts/customer-journey-day-one-readiness.mjs",
    "qa:week": "node scripts/customer-journey-weekly-readiness.mjs",
    "qa:fixtures": "node scripts/customer-journey-fixture-checklist.mjs",
    "qa:ledger": "node scripts/customer-journey-ledger-template.mjs",
    "qa:flows": "node scripts/customer-journey-flow-map.mjs",
    "qa:focus": "node scripts/customer-journey-focus.mjs",
    "qa:handoffs": "node scripts/customer-journey-handoffs.mjs",
    "qa:matrix": "node scripts/customer-journey-feature-matrix.mjs",
    "qa:gaps": "node scripts/customer-journey-gap-report.mjs",
    "qa:evidence": "node scripts/customer-journey-evidence-checklist.mjs",
    "qa:triage": "node scripts/customer-journey-triage-guide.mjs",
    "qa:results": "node scripts/customer-journey-results-summary.mjs",
    "qa:launch": "node scripts/customer-journey-launch-readiness.mjs",
    "verify": "npm run lint && npm run typecheck && npm test && npm run check:extension && npm run build",
    "db:migrations": "supabase migration list",
    "db:push:dry": "supabase db push --dry-run",
    "db:push": "supabase db push",
    "db:audit:tiq": "node scripts/audit-tiq-league-schema.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/qrcode": "^1.5.6",
    "framer-motion": "^12.38.0",
    "next": "16.2.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tesseract.js": "^7.0.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "supabase": "^2.98.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
